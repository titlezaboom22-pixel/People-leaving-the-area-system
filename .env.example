# Firebase Configuration
# สร้าง Firebase project ที่ https://console.firebase.google.com
# แล้วคัดลอกค่า config มาวางที่นี่
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# App Configuration
VITE_APP_ID=visitor-soc-001
VITE_PUBLIC_URL=https://your-project.web.app

# Email server (cloud)
VITE_EMAIL_API=https://your-email-server.onrender.com

# ===== Security Layer 1 =====
# สร้าง API key ด้วย: node -e "console.log('tbkk_' + require('crypto').randomBytes(24).toString('base64url'))"
# VITE_API_KEY ต้องตรงกับ API_KEY ที่ตั้งใน Render env vars
VITE_API_KEY=tbkk_change_me_before_production
API_KEY=tbkk_change_me_before_production

# Domain ที่อนุญาตให้ส่ง email ได้ (ป้องกันสแปม)
RECIPIENT_DOMAIN_ALLOWLIST=tbkk.co.th,tbk.co.th

# SMTP Configuration (สำหรับ email server)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=no-reply@tbkk.co.th
SMTP_PASS=
SMTP_FROM=no-reply@tbkk.co.th
SMTP_FROM_NAME=SOC Systems - TBKK Group

# EmailJS (optional fallback — ถ้า SMTP ใช้ไม่ได้)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
